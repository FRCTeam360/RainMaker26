<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<!--
  Checkstyle suppressions for RainMaker26.
  Suppresses findings in auto-generated files, vendor libraries, and files
  where the flagged pattern is intentional (e.g., lookup tables in constants files).
-->
<suppressions>

    <!-- Auto-generated by GVersion — do not lint -->
    <suppress files="BuildConstants\.java" checks=".*"/>

    <!-- CTRE-generated drivetrain tuning files — heavily vendor-influenced -->
    <suppress files="src[/\\]main[/\\]java[/\\]frc[/\\]robot[/\\]generated[/\\].*\.java" checks=".*"/>

    <!-- Vendor library included as source — do not modify or lint -->
    <suppress files="LimelightHelpers\.java" checks=".*"/>

    <!-- Vendor-influenced CTRE drivetrain wrapper — naming and style differ by design -->
    <suppress files="CommandSwerveDrivetrain\.java" checks=".*"/>

    <!--
      Constants files: suppress MagicNumber and ConstantName.
      Physical constants, lookup tables, and CAN ID assignments use raw numbers
      and camelCase map names intentionally (e.g. shotHoodAngleMap) — these
      predate the linter and renaming would require cascading reference updates.
    -->
    <suppress files="Constants\.java" checks="MagicNumber|ConstantName"/>
    <suppress files="ShooterConstants\.java" checks="MagicNumber"/>
    <suppress files="FieldConstants\.java" checks="MagicNumber"/>
    <suppress files="VisionSimConstants\.java" checks="MagicNumber"/>

    <!--
      Noop IO implementations: suppress EmptyBlock and NeedBraces.
      These classes intentionally have empty method bodies as no-op stubs.
    -->
    <suppress files=".*IONoop\.java" checks="EmptyBlock|NeedBraces"/>

    <!--
      IO interfaces: suppress MissingJavadocMethod.
      Interface method declarations are documented on the implementing classes.
    -->
    <suppress files=".*IO\.java" checks="MissingJavadocMethod|JavadocMethod"/>

</suppressions>
