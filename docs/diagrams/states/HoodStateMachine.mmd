%% Hood State Machine
%% Reflects actual code in Hood.java
%% Two-layer state: WantedState drives InternalState
stateDiagram-v2
    state "Wanted: IDLE" as WIDLE
    state "Wanted: AIMING" as WAIMING

    [*] --> WIDLE
    WIDLE --> WAIMING : SuperStructure sets AIMING
    WAIMING --> WIDLE : SuperStructure sets IDLE

    state WIDLE {
        OFF
    }

    state WAIMING {
        [*] --> MOVING
        MOVING --> AT_SETPOINT : |position - target| < 0.5°
        AT_SETPOINT --> MOVING : |position - target| >= 0.5°
    }

    note right of WIDLE : Position set to 0.0°
    note right of WAIMING : Position set to ShotCalculator angle<br>(hub or outpost depending on SuperState)
    note right of AT_SETPOINT : Ready — ShooterStateMachine checks<br>this to transition to FIRING
