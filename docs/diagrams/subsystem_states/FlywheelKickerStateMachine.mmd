---
title: FlywheelKicker State Machine
---
stateDiagram-v2
    state "Wanted: IDLE" as WIDLE
    state "Wanted: KICKING" as WKICKING
    state "Wanted: REVERSING" as WREVERSING

    [*] --> WIDLE
    WIDLE --> WKICKING : ShooterStateMachine<br>sets KICKING
    WKICKING --> WIDLE : ShooterStateMachine<br>sets IDLE
    WIDLE --> WREVERSING : ShooterStateMachine<br>sets REVERSING
    WREVERSING --> WIDLE : ShooterStateMachine<br>sets IDLE
    WKICKING --> WREVERSING : ShooterStateMachine<br>sets REVERSING
    WREVERSING --> WKICKING : ShooterStateMachine<br>sets KICKING

    state WKICKING {
        [*] --> SPINNING_UP

        SPINNING_UP --> AT_SETPOINT : Debounced velocity<br>within 100 RPM of target
        AT_SETPOINT --> RECOVERING : Ball fired detected<br>(debounced velocity dip,<br>40ms falling-edge)
        RECOVERING --> AT_SETPOINT : Debounced velocity<br>within 100 RPM of target
        RECOVERING --> UNDER_KICKING : Sustained RPM drop<br>(200ms falling-edge debounce)
        UNDER_KICKING --> AT_SETPOINT : Debounced velocity<br>within 100 RPM of target
    }

    state WREVERSING {
        [*] --> REVERSING_STATE
    }

    note right of WIDLE : Motor duty cycle = 0.0
    note right of WKICKING : Target velocity = 4500 RPM<br>Bang-bang control
    note right of SPINNING_UP : Duty-cycle bang-bang<br>Max acceleration
    note right of AT_SETPOINT : Torque-current bang-bang<br>Bounded hold<br>ShooterStateMachine checks this
    note right of RECOVERING : Duty-cycle bang-bang<br>Re-spinning after note passed
    note right of UNDER_KICKING : Duty-cycle bang-bang<br>Too many rapid shots
    note right of WREVERSING : Reverses kicker to clear jams
    note right of REVERSING_STATE : Duty cycle = -0.85
