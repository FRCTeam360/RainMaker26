---
title: SuperStructure State Machine
---
stateDiagram-v2
    direction TB
    [*] --> DEFAULT_WANTED

    %% DEFAULT Wanted State Container
    state "WantedState: DEFAULT" as DEFAULT_WANTED {
        [*] --> StateDefault
        StateDefault: DEFAULT (internal)
        
        note right of StateDefault
            TargetSelection → AUTO
            ShooterStateMachine → PASSIVE_SHOOTER
              ↳ Internal: WAITING
            Intake → OFF
            Indexer → OFF
            IntakePivot → DEPLOYED
            HopperRoller → OFF
            Flywheel → IDLE (via ShooterStateMachine)
            Hood → DUCKED (via ShooterStateMachine)
            FlywheelKicker → IDLE (via ShooterStateMachine)
            
            Passive shooter state with hood ducking
        end note
    }

    %% IDLE Wanted State Container
    state "WantedState: IDLE" as IDLE_WANTED {
        [*] --> StateIdle
        StateIdle: IDLE (internal)
        
        note right of StateIdle
            All subsystems stopped
            Intake → OFF
            Indexer → OFF
            IntakePivot → OFF
            HopperRoller → OFF
            ShooterStateMachine → IDLE
              ↳ Flywheel → IDLE
              ↳ Hood → IDLE
              ↳ FlywheelKicker → IDLE
            
            Used in disabled/test modes only
        end note
    }

    %% INTAKING Wanted State Container
    state "WantedState: INTAKING" as INTAKING_WANTED {
        [*] --> StateIntaking
        StateIntaking: INTAKING (internal)
        
        note right of StateIntaking
            Intake → INTAKING
            IntakePivot → DEPLOYED
            HopperRoller → PREVENT_JAM
            Indexer → ASSIST_INTAKING
            ShooterStateMachine → IDLE
              ↳ Flywheel → IDLE
              ↳ Hood → IDLE
              ↳ FlywheelKicker → IDLE
            
            Full intake mode
        end note
    }

    %% SHOOT_AT_HUB Wanted State Container
    state "WantedState: SHOOT_AT_HUB" as SHOOT_HUB_WANTED {
        [*] --> StateShootingAtHub
        StateShootingAtHub: SHOOTING_AT_HUB (internal)
        
        note right of StateShootingAtHub
            TargetSelection → HUB
            ShooterStateMachine → SHOOTING
              ↳ Internal: PREPARING_TO_FIRE ↔ FIRING
            Intake → OFF (until FIRING)
            Indexer → OFF (until FIRING)
            IntakePivot → OFF (until FIRING)
            HopperRoller → OFF (until FIRING)
            
            When ShooterStateMachine.state == FIRING:
              Intake → ASSIST_SHOOTING
              Indexer → INDEXING
              IntakePivot → AGITATE_HOPPER
              HopperRoller → ROLLING
            
            Shot calculator: hubShotCalculator
        end note
    }

    %% SHOOT_AT_OUTPOST Wanted State Container
    state "WantedState: SHOOT_AT_OUTPOST" as SHOOT_OUTPOST_WANTED {
        [*] --> StatePassing
        StatePassing: PASSING (internal)
        
        note right of StatePassing
            TargetSelection → OUTPOST
            ShooterStateMachine → SHOOTING
              ↳ Internal: PREPARING_TO_FIRE ↔ FIRING
            Intake → OFF (until FIRING)
            Indexer → OFF (until FIRING)
            IntakePivot → OFF (until FIRING)
            HopperRoller → OFF (until FIRING)
            
            When ShooterStateMachine.state == FIRING:
              Intake → ASSIST_SHOOTING
              Indexer → INDEXING
              IntakePivot → AGITATE_HOPPER
              HopperRoller → ROLLING
            
            Shot calculator: passCalculator
        end note
    }

    %% AUTO_CYCLE_SHOOTING Wanted State Container
    state "WantedState: AUTO_CYCLE_SHOOTING" as AUTO_CYCLE_WANTED {
        [*] --> AutoChoice
        
        state AutoChoice <<choice>>
        AutoChoice --> StateAutoHub : TargetSelection<br>resolves to AT_HUB
        AutoChoice --> StateAutoOutpost : TargetSelection<br>resolves to AT_OUTPOST
        
        StateAutoHub: SHOOTING_AT_HUB (internal)
        StateAutoOutpost: PASSING (internal)
        
        note right of StateAutoHub
            TargetSelection → AUTO → AT_HUB
            Same behavior as SHOOT_AT_HUB
            Auto-selected based on alliance zone
        end note
        
        note right of StateAutoOutpost
            TargetSelection → AUTO → AT_OUTPOST
            Same behavior as SHOOT_AT_OUTPOST
            Auto-selected based on alliance zone
        end note
    }

    %% UNJAMMING Wanted State Container
    state "WantedState: UNJAMMING" as UNJAMMING_WANTED {
        [*] --> StateUnjamming
        StateUnjamming: UNJAMMING (internal)
        
        note right of StateUnjamming
            Indexer → REVERSING
            HopperRoller → UNJAMMING
            IntakePivot → DEPLOYED
            Intake → OFF
            ShooterStateMachine → REVERSING
              ↳ Flywheel → IDLE
              ↳ Hood → IDLE
              ↳ FlywheelKicker → REVERSING
            
            Clears jams by reversing
        end note
    }

    %% STOWED Wanted State Container
    state "WantedState: STOWED" as STOWED_WANTED {
        [*] --> StateStowing
        StateStowing: STOWING (internal)
        
        note right of StateStowing
            IntakePivot → STOWED
            
            All other subsystems maintain
            previous state (no explicit control)
        end note
    }

    %% Transitions between wanted states
    DEFAULT_WANTED --> INTAKING_WANTED : Driver holds intake button
    DEFAULT_WANTED --> SHOOT_HUB_WANTED : Driver holds force hub button
    DEFAULT_WANTED --> SHOOT_OUTPOST_WANTED : Driver holds force outpost button
    DEFAULT_WANTED --> AUTO_CYCLE_WANTED : Driver holds auto cycle button
    DEFAULT_WANTED --> UNJAMMING_WANTED : Driver presses A button
    DEFAULT_WANTED --> STOWED_WANTED : Driver presses Y button

    INTAKING_WANTED --> DEFAULT_WANTED : Driver releases intake button
    SHOOT_HUB_WANTED --> DEFAULT_WANTED : Driver releases force hub button
    SHOOT_OUTPOST_WANTED --> DEFAULT_WANTED : Driver releases force outpost button
    AUTO_CYCLE_WANTED --> DEFAULT_WANTED : Driver releases auto cycle button
    UNJAMMING_WANTED --> DEFAULT_WANTED : Driver releases A button

    IDLE_WANTED --> DEFAULT_WANTED : Robot enters autonomous/teleop

    %% Defined but not yet implemented
    state "Not Yet Implemented" as NYI {
        DEFENSE
        X_OUT
        EJECTING
    }
