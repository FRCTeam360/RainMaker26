title: High-Level Architecture
---
graph TD
    Robot["Robot.java<br/>(Main Loop)"] --> RC["RobotContainer<br/>(Wiring & Bindings)"]

    RC --> SS["SuperStructure<br/>(Master Coordinator)"]
    RC --> Drive["CommandSwerveDrivetrain"]
    RC --> Vis["Vision"]
    RC --> Climb["Climber"]
    RC --> SC["ShotCalculators<br/>(Hub & Pass)"]

    SS --> ShooterSM["ShooterStateMachine"]
    SS --> IntakeSM["IntakeStateMachine"]
    SS --> TargetSM["TargetSelectionStateMachine"]

    ShooterSM --> FW["Flywheel"]
    ShooterSM --> Hood["Hood"]
    ShooterSM --> Kicker["FlywheelKicker"]

    IntakeSM --> IR["IntakeRoller"]
    IntakeSM --> IP["IntakePivot"]

    SS --> Idx["Indexer"]
    SS --> HR["HopperRoller"]

    TargetSM --> SC

    Vis -->|"Pose Estimates"| Drive

    SC -->|"Hood Angle &<br/>Flywheel Speed"| ShooterSM

