graph TD
    subgraph "Robot Periodic Loop"
        Pre["preSchedulerUpdate()<br/>Cache shot calculations"] --> Sched["CommandScheduler.run()"]
        Sched --> Post["postSchedulerUpdate()<br/>Flush NetworkTables"]
    end

    subgraph "SuperStructure Periodic"
        US["updateState()<br/>Wanted -> Internal"] --> TSM["TargetSelection.update()<br/>Hub vs Outpost"]
        TSM --> SSM["Shooter.update()<br/>Check readiness"]
        SSM --> ISM["Intake.update()<br/>Resolve intake state"]
        ISM --> AS["applyStates()<br/>Set subsystem wanted states"]
    end

    Sched --> US

