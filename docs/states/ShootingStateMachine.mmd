%% Shooting Sub-State Machine (inside SHOOT_AT_HUB or SHOOT_AT_OUTPOST)
%% Reflects actual code in ShooterStateMachine.java
stateDiagram-v2
    [*] --> PREPARING_TO_FIRE

    %% Entry into FIRING requires all three conditions
    PREPARING_TO_FIRE --> FIRING : Flywheel AT_SETPOINT<br>AND Hood AT_SETPOINT<br>AND drivetrain aligned

    %% FIRING is sticky — stays through RECOVERING (bang-bang oscillations).
    %% Only reverts when flywheel reports UNDER_SHOOTING (sustained RPM drop).
    FIRING --> PREPARING_TO_FIRE : Flywheel UNDER_SHOOTING<br>OR hood loses position<br>OR alignment lost

    %% Exit back to SuperStructure IDLE
    PREPARING_TO_FIRE --> [*] : SuperState leaves<br>SHOOT_AT_HUB / SHOOT_AT_OUTPOST
    FIRING --> [*] : SuperState leaves<br>SHOOT_AT_HUB / SHOOT_AT_OUTPOST

    note right of PREPARING_TO_FIRE : Flywheel → SHOOTING (spinning up)<br>Hood → AIMING (moving to angle)<br>FlywheelKicker → IDLE
    note right of FIRING : Flywheel → SHOOTING (holding/recovering)<br>Hood → AIMING (at setpoint)<br>FlywheelKicker → KICKING<br>Stays in FIRING through brief RPM dips<br>(RECOVERING state in flywheel)
