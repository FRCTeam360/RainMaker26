%% Hood State Machine
%% Reflects actual code in Hood.java
%% Two-layer state: WantedState drives CurrentState
stateDiagram-v2
    state "Wanted: IDLE" as WIDLE
    state "Wanted: SHOOTING" as WSHOOTING

    [*] --> WIDLE
    WIDLE --> WSHOOTING : SuperStructure sets SHOOTING
    WSHOOTING --> WIDLE : SuperStructure sets IDLE

    state WSHOOTING {
        [*] --> MOVING
        MOVING --> AT_SETPOINT : |position - target| < 0.5
        AT_SETPOINT --> MOVING : |position - target| >= 0.5
    }

    note right of WIDLE : Position set to 0.0
    note right of WSHOOTING : Position set to ShotCalculator angle<br>(hub or outpost depending on SuperState)
    note right of AT_SETPOINT : Ready — SuperStructure checks<br>this to transition to FIRING
